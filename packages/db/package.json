{
  "name": "@afterdark/db",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./config/env.server": "./src/config/env.server.ts"
  },
  "scripts": {
    "type-check": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:reset": "node -e \"const fs=require('fs');const p='../../local.db';for (const f of [p,p+'-wal',p+'-shm']) { try { fs.unlinkSync(f) } catch {} }\" && drizzle-kit migrate && tsx src/seed/roles.ts",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx src/seed/roles.ts"
  },
  "dependencies": {
    "@afterdark/types": "workspace:*",
    "@afterdark/validators": "workspace:*",
    "@libsql/client": "0.17.3",
    "drizzle-orm": "0.43.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "22.15.0",
    "drizzle-kit": "0.31.1",
    "tsx": "4.19.4",
    "typescript": "6.0.3"
  }
}
