{
  "name": "afterdark",
  "private": true,
  "scripts": {
    "dev": "pnpm --parallel --filter \"./apps/*\" dev",
    "dev:web": "pnpm --filter @afterdark/web dev",
    "dev:dashboard": "pnpm --filter @afterdark/dashboard dev",
    "dev:api": "pnpm --filter @afterdark/api dev",
    "build": "pnpm --recursive --filter \"./apps/*\" build",
    "type-check": "pnpm --recursive type-check",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "9.1.7",
    "lint-staged": "15.4.3",
    "oxfmt": "0.51.0",
    "oxlint": "1.66.0",
    "typescript": "6.0.3"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "oxlint --fix",
      "oxfmt"
    ]
  },
  "packageManager": "pnpm@11.0.9+sha512.34ce82e6780233cf9cad8685029a8f81d2e06196c5a9bad98879f7424940c6817c4e4524fb7d38b8553ceed48b9758b8ebaf1abd3600c232c4c8cf7366086f38"
}
