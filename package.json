{
  "name": "afterdark",
  "private": true,
  "scripts": {
    "dev": "pnpm --parallel --filter \"./apps/*\" dev",
    "dev:web": "pnpm --filter @afterdark/web dev",
    "dev:dashboard": "pnpm --filter @afterdark/dashboard dev",
    "dev:api": "pnpm --filter @afterdark/api dev",
    "storybook": "pnpm --filter @afterdark/ui storybook",
    "build-storybook": "pnpm --filter @afterdark/ui build-storybook",
    "build": "pnpm --recursive --filter \"./apps/*\" build",
    "type-check": "pnpm --recursive type-check",
    "lint": "oxlint -c oxlint.json .",
    "lint:fix": "oxlint -c oxlint.json --fix .",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "check": "pnpm type-check && pnpm lint && pnpm format:check",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "9.1.7",
    "lint-staged": "17.0.7",
    "oxfmt": "0.55.0",
    "oxlint": "1.66.0",
    "typescript": "6.0.3"
  },
  "packageManager": "pnpm@11.0.9+sha512.34ce82e6780233cf9cad8685029a8f81d2e06196c5a9bad98879f7424940c6817c4e4524fb7d38b8553ceed48b9758b8ebaf1abd3600c232c4c8cf7366086f38",
  "pnpm": {
    "packageExtensions": {
      "tsconfck@*": {
        "peerDependencies": {
          "typescript": ">=5.0.0"
        }
      }
    },
    "peerDependencyRules": {
      "allowedVersions": {
        "tsconfck>typescript": "6",
        "typescript": "6"
      }
    }
  }
}
